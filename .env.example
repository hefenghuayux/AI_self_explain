FIRST_ROUND_SUPPORT_LIMIT=6
SECOND_ROUND_SUPPORT_LIMIT=3
NO_PROGRESS_LIMIT=2
GUIDED_QUESTION_REQUEST_LIMIT=2

AI_REQUEST_TIMEOUT_SECONDS=60
AI_TRANSPORT_MAX_RETRIES=2
AI_SCHEMA_MAX_RETRIES=1
AI_RETRY_BACKOFF_SECONDS=1,2

ASR_REQUEST_TIMEOUT_SECONDS=60
ASR_TRANSPORT_MAX_RETRIES=2
ASR_RETRY_BACKOFF_SECONDS=1,2
ASR_AUDIO_FORMAT=pcm
ASR_SAMPLE_RATE_HZ=16000
ASR_CHANNELS=1
ASR_FRAME_DURATION_MS=200
ASR_SEMANTIC_PUNCTUATION_ENABLED=false

AUDIO_MAX_SIZE_MIB=20
AUDIO_MAX_DURATION_SECONDS=300

DATABASE_BUSY_TIMEOUT_SECONDS=5

LOG_MAX_SIZE_MIB=10
LOG_BACKUP_COUNT=5

AI_PROVIDER=replace-with-ai-provider
AI_BASE_URL=https://example.com/v1
AI_API_KEY=replace-with-ai-api-key
AI_MODEL=replace-with-ai-model

ASR_PROVIDER=AlibabaCloudBailian
ASR_BASE_URL=wss://replace-with-workspace-id.cn-beijing.maas.aliyuncs.com/api-ws/v1/inference
ASR_API_KEY=replace-with-asr-api-key
ASR_MODEL=fun-asr-realtime

PROMPT_VERSION=v1
DATABASE_URL=sqlite:///./data/database/ai_self_explain.db
AUDIO_STORAGE_DIR=./data/audio
LOG_DIR=./data/logs

BACKEND_PROXY_TARGET=http://127.0.0.1:8000
